-- ==========================================
-- GREEN CREDIT CAMPUS RECYCLING DATABASE
-- ==========================================

-- TABLE CREATION
CREATE TABLE Waste_Categories (
    CategoryID INT PRIMARY KEY,
    CategoryName VARCHAR(50) NOT NULL,
    CreditPerKg NUMBER(5,2) NOT NULL
);

CREATE TABLE Campus_Bins (
    BinID INT PRIMARY KEY,
    Location VARCHAR(100) NOT NULL,
    CategoryID INT,
    FOREIGN KEY (CategoryID) REFERENCES Waste_Categories(CategoryID)
);

CREATE TABLE Students (
    RollNumber INT PRIMARY KEY,
    Name VARCHAR(100) NOT NULL,
    Email VARCHAR(100) UNIQUE NOT NULL,
    HostelBlock VARCHAR(10) NOT NULL,
    TotalCredits NUMBER(10,2) DEFAULT 0
);

CREATE TABLE Rewards (
    RewardID INT PRIMARY KEY,
    RewardName VARCHAR(100) NOT NULL,
    CreditCost NUMBER(10,2) NOT NULL,
    StockQuantity INT NOT NULL CHECK (StockQuantity >= 0)
);

CREATE TABLE Deposits (
    DepositID INT PRIMARY KEY,
    RollNumber INT,
    BinID INT,
    Weight NUMBER(5,2) NOT NULL CHECK (Weight > 0),
    CreditsEarned NUMBER(10,2),
    DepositDate DATE DEFAULT SYSDATE,
    FOREIGN KEY (RollNumber) REFERENCES Students(RollNumber),
    FOREIGN KEY (BinID) REFERENCES Campus_Bins(BinID)
);

CREATE TABLE Redemptions (
    RedemptionID INT PRIMARY KEY,
    RollNumber INT,
    RewardID INT,
    RedemptionDate DATE DEFAULT SYSDATE,
    FOREIGN KEY (RollNumber) REFERENCES Students(RollNumber),
    FOREIGN KEY (RewardID) REFERENCES Rewards(RewardID)
);

-- PL/SQL
CREATE OR REPLACE TRIGGER Update_Student_Credits
AFTER INSERT ON Deposits
FOR EACH ROW
BEGIN
    UPDATE Students
    SET TotalCredits = TotalCredits + :NEW.CreditsEarned
    WHERE RollNumber = :NEW.RollNumber;
END;
/
