-- DEPOSIT STORED PROCEDURE

CREATE OR REPLACE PROCEDURE Log_Campus_Deposit (
    p_RollNumber IN INT,
    p_BinID IN INT,
    p_Weight IN NUMBER
) AS
    v_CategoryID INT;
    v_CreditPerKg NUMBER(5,2);
    v_CreditsEarned NUMBER(10,2);
    v_DepositID INT;
BEGIN
    SELECT CategoryID INTO v_CategoryID
    FROM Campus_Bins
    WHERE BinID = p_BinID;
    SELECT CreditPerKg INTO v_CreditPerKg
    FROM Waste_Categories
    WHERE CategoryID = v_CategoryID;
    v_CreditsEarned := p_Weight * v_CreditPerKg;
    SELECT NVL(MAX(DepositID), 1000) + 1 INTO v_DepositID
    FROM Deposits;
    INSERT INTO Deposits (DepositID, RollNumber, BinID, Weight, CreditsEarned)
    VALUES (v_DepositID, p_RollNumber, p_BinID, p_Weight, v_CreditsEarned);

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Deposit Logged Successfully. Credits Earned: ' || v_CreditsEarned);
    
EXCEPTION
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Error: Invalid Bin ID.');
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('An unexpected error occurred.');
        ROLLBACK;
END;
/

-- REWARD REDEMPTION

CREATE OR REPLACE PROCEDURE Redeem_Reward (
    p_RollNumber IN INT,
    p_RewardID IN INT
) AS
    v_CreditCost NUMBER(10,2);
    v_StockQuantity INT;
    v_TotalCredits NUMBER(10,2);
    v_RedemptionID INT;
    Insufficient_Credits EXCEPTION;
    Out_Of_Stock EXCEPTION;
BEGIN
    SELECT CreditCost, StockQuantity INTO v_CreditCost, v_StockQuantity
    FROM Rewards
    WHERE RewardID = p_RewardID;
    
    IF v_StockQuantity <= 0 THEN
        RAISE Out_Of_Stock;
    END IF;

    SELECT TotalCredits INTO v_TotalCredits
    FROM Students
    WHERE RollNumber = p_RollNumber;
    
    IF v_TotalCredits < v_CreditCost THEN
        RAISE Insufficient_Credits;
    END IF;

    UPDATE Students
    SET TotalCredits = TotalCredits - v_CreditCost
    WHERE RollNumber = p_RollNumber;
    
    UPDATE Rewards
    SET StockQuantity = StockQuantity - 1
    WHERE RewardID = p_RewardID;

    SELECT NVL(MAX(RedemptionID), 5000) + 1 INTO v_RedemptionID
    FROM Redemptions;
    
    INSERT INTO Redemptions (RedemptionID, RollNumber, RewardID)
    VALUES (v_RedemptionID, p_RollNumber, p_RewardID);

    COMMIT;
    DBMS_OUTPUT.PUT_LINE('Success! Reward Redeemed. Remaining Balance: ' || (v_TotalCredits - v_CreditCost));

EXCEPTION
    WHEN Out_Of_Stock THEN
        DBMS_OUTPUT.PUT_LINE('Transaction Failed: This reward is currently out of stock.');
        ROLLBACK;
    WHEN Insufficient_Credits THEN
        DBMS_OUTPUT.PUT_LINE('Transaction Failed: Insufficient credits. You need ' || v_CreditCost || ' but have ' || v_TotalCredits);
        ROLLBACK;
    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Transaction Failed: Invalid Roll Number or Reward ID.');
        ROLLBACK;
    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('System Error: An unexpected error occurred. Transaction rolled back.');
        ROLLBACK;
END;
/

-- PL/SQL CURSOR
SET SERVEROUTPUT ON;

DECLARE
    CURSOR c_HostelReport IS
        SELECT s.HostelBlock, SUM(d.Weight) as TotalWeight, SUM(d.CreditsEarned) as TotalCredits
        FROM Students s
        JOIN Deposits d ON s.RollNumber = d.RollNumber
        GROUP BY s.HostelBlock
        ORDER BY TotalWeight DESC;
        
    v_Hostel VARCHAR(10);
    v_Weight NUMBER(10,2);
    v_Credits NUMBER(10,2);
BEGIN
    DBMS_OUTPUT.PUT_LINE('--------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE(' CAMPUS SUSTAINABILITY REPORT (BY HOSTEL) ');
    DBMS_OUTPUT.PUT_LINE('--------------------------------------------------');
    DBMS_OUTPUT.PUT_LINE('Hostel | Total Waste (kg) | Total Credits Issued');
    DBMS_OUTPUT.PUT_LINE('--------------------------------------------------');
    
    OPEN c_HostelReport;
    
    LOOP
        FETCH c_HostelReport INTO v_Hostel, v_Weight, v_Credits;
        EXIT WHEN c_HostelReport%NOTFOUND; -- Exit loop when no more rows
        
        DBMS_OUTPUT.PUT_LINE(RPAD(v_Hostel, 7) || ' | ' || RPAD(v_Weight, 17) || ' | ' || v_Credits);
    END LOOP;
    
    CLOSE c_HostelReport;
    
    DBMS_OUTPUT.PUT_LINE('--------------------------------------------------');
END;
/
-- ADMIN DASHBOARD
CREATE OR REPLACE VIEW Admin_Hostel_Dashboard AS
SELECT 
    s.HostelBlock,
    COUNT(DISTINCT s.RollNumber) AS Participating_Students,
    SUM(d.Weight) AS Total_Kg_Recycled,
    SUM(d.CreditsEarned) AS Total_Credits_Issued
FROM Students s
JOIN Deposits d ON s.RollNumber = d.RollNumber
GROUP BY s.HostelBlock
HAVING SUM(d.Weight) > 0
ORDER BY Total_Kg_Recycled DESC;

-- PL/SQL FUNCTION
CREATE OR REPLACE FUNCTION Calculate_Credits (
    p_CategoryID IN INT,
    p_Weight IN NUMBER
) RETURN NUMBER AS
    v_CreditPerKg NUMBER(5,2);
    v_TotalCredits NUMBER(10,2);
BEGIN
    SELECT CreditPerKg INTO v_CreditPerKg
    FROM Waste_Categories
    WHERE CategoryID = p_CategoryID;

    v_TotalCredits := p_Weight * v_CreditPerKg;

    RETURN v_TotalCredits;
    
EXCEPTION
    WHEN NO_DATA_FOUND THEN
        RETURN 0;
    WHEN OTHERS THEN
        RETURN -1;
END;
/
